{
  "expo": {
    "name": "MarketSim Pro",
    "slug": "marketsim-pro-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unnyanr11.marketsimpro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.unnyanr11.marketsimpro"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0ea5e9"
        }
      ],
      "expo-build-properties",
      "expo-secure-store"
    ],
    "owner": "unnyanr11",
    "extra": {
      "eas": {
        "projectId": "5c431b00-49db-420a-abfd-4863c68a7cfb"
      }
    }
  }
}
